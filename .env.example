# ask-kip configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Telegram bot token for your Kip bot
# Find this in your OpenClaw config or from @BotFather
BOT_TOKEN=your-telegram-bot-token-here

# Your Telegram user ID (chat_id)
# Ask @userinfobot on Telegram if you don't know yours
CHAT_ID=your-telegram-chat-id-here

# Whisper model path (optional — defaults to whisper.cpp/models/ggml-base.en.bin)
# Uncomment and change if you want to use a different model
# WHISPER_MODEL_PATH=/path/to/your/model.bin

# Whisper language (optional — defaults to "en")
# WHISPER_LANG=en
