# ask-kip configuration
# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# Messages are sent from YOUR Telegram user account (via MTProto), so Kip sees
# them as coming from you — not from the bot. This requires API credentials
# tied to your account.

# Telegram API credentials for your user account.
# Create them at https://my.telegram.org → API development tools.
TELEGRAM_API_ID=your-api-id-here
TELEGRAM_API_HASH=your-api-hash-here

# Where to send your voice queries — the destination Kip listens to.
# Usually your Kip bot's @username (e.g. @my_kip_bot), or a numeric chat id.
KIP_TARGET=@kip_palewire_bot

# Telethon session file (optional — defaults to ./.telegram.session)
# Created by `make login`. Keep it private; it grants access to your account.
# TELEGRAM_SESSION=/path/to/.telegram.session

# Whisper model path (optional — defaults to whisper.cpp/models/ggml-base.en.bin)
# Uncomment and change if you want to use a different model
# WHISPER_MODEL_PATH=/path/to/your/model.bin

# Whisper language (optional — defaults to "en")
# WHISPER_LANG=en
